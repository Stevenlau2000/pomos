# POMOS v6.0 — 根环境变量示例
# 复制为 .env 后按需修改；后端读取 backend/.env，前端读取 frontend/.env.local

# ---------- 后端 (backend/.env) ----------
# OpenAI（或兼容端点）密钥；留空则 Orchestrator 走 mock 链路，应用仍可启动
OPENAI_API_KEY=
# 模型名，默认 gpt-5.5，可改为 gpt-4o / claude-3-5-sonnet / gemini-1.5-pro 等
LLM_MODEL=gpt-5.5
# OpenAI 基础 URL（如需代理或兼容网关）
OPENAI_BASE_URL=https://api.openai.com/v1

# 数据库：开发期默认 SQLite；切 PostgreSQL 时改为下方 postgres URL
DATABASE_URL=sqlite:///./pomos.db
# DATABASE_URL=postgresql://pomos:pomos_dev@localhost:5432/pomos

# Redis（仅预留，不强制）
REDIS_URL=redis://localhost:6379/0

# CORS：允许的前端源
CORS_ORIGINS=http://localhost:3000

# ---------- 前端 (frontend/.env.local) ----------
NEXT_PUBLIC_API_BASE=http://localhost:8000
