# ============================================================
# POMOS 后端环境配置 —— 复制本文件为 .env 后填入真实值
# cp .env.example .env
# ============================================================

# ---------------- LLM 多供应商密钥 ----------------
# 只需填入其中任意一个已开通的密钥，POMOS 即会调用对应真实模型；
# 全部留空则走离线 Mock（返回占位文本，链路不报错）。
# 优先顺序（LLM_PROVIDER 留空时自动探测）：openai > deepseek > qwen > moonshot > zhipu > gemini > anthropic

# OpenAI
OPENAI_API_KEY=
# DeepSeek（deepseek-chat / deepseek-reasoner）
DEEPSEEK_API_KEY=
# 阿里通义千问（qwen-max / qwen-plus / qwen-turbo）
DASHSCOPE_API_KEY=
# 月之暗面 Kimi（moonshot-v1-8k / moonshot-v1-32k）
MOONSHOT_API_KEY=
# 智谱 GLM（glm-4 / glm-4-plus）
ZHIPU_API_KEY=
# Google Gemini（gemini-1.5-pro / gemini-2.0-flash）
GEMINI_API_KEY=
# Anthropic Claude（claude-sonnet-4-20250514 / claude-opus-4-...）
ANTHROPIC_API_KEY=

# ---------------- 供应商与模型选择 ----------------
# 留空=自动探测已配置的密钥；可显式指定：openai/deepseek/qwen/moonshot/zhipu/gemini/anthropic/custom
LLM_PROVIDER=
# 模型名：留空则用对应供应商默认模型；指定供应商后建议填对应模型
LLM_MODEL=
# 采样温度 / 最大生成 token
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1200

# ---------------- 自定义 OpenAI 兼容端点 ----------------
# 仅当 LLM_PROVIDER=custom 时使用：接入任意 OpenAI 兼容网关（如本地 Ollama、vLLM、第三方代理）
LLM_BASE_URL=
LLM_API_KEY=

# ---------------- 数据库 ----------------
# 开发期默认 SQLite；可改为 postgresql://user:pwd@host:5432/pomos
DATABASE_URL=sqlite:///./pomos.db

# ---------------- Redis（仅预留，不强制连接）----------------
REDIS_URL=redis://localhost:6379/0

# ---------------- 跨域 ----------------
# 允许的前端来源，逗号分隔
CORS_ORIGINS=http://localhost:3000
